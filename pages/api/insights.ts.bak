import type { NextApiRequest, NextApiResponse } from 'next'

type InsightItem = {
  id: string
  title: string
  summary: string
  sourceType: 'market' | 'news'
  sourceName: string
  sourceUrl?: string
  relatedSymbols?: string[]
  publishedAt: string
  createdAt: string
  dedupeKey: string
}

type InsightsResponse = { items: InsightItem[]; serverTime: string; cached: boolean; sources: string[] }

const CACHE_TTL_MS = 60 * 1000

declare global {
  var __insightsCache: Map<string, { ts: number; payload: InsightsResponse }> | undefined
}

function clamp(n: number, lo: number, hi: number) {
  return Math.max(lo, Math.min(hi, n))
}

function baseUrlFromReq(req: NextApiRequest) {
  const proto = String(req.headers['x-forwarded-proto'] || 'http')
  const host = String(req.headers.host || '')
  if (!host) return ''
  return `${proto}://${host}`
}

function bucketKey(d: Date) {
  const dt = new Date(d)
  dt.setSeconds(0, 0)
  const m = dt.getMinutes()
  dt.setMinutes(m - (m % 5))
  return dt.toISOString().slice(0, 16)
}

function safeNum(x: any, fallback = 0) {
  const v = Number(x)
  return Number.isFinite(v) ? v : fallback
}

async function fetchJson(url: string, timeoutMs: number) {
  const controller = new AbortController()
  const id = setTimeout(() => controller.abort(), timeoutMs)
  try {
    const res = await fetch(url, { method: 'GET', cache: 'no-store', signal: controller.signal, headers: { 'user-agent': 'HybridTradeAI/1.0' } })
    const json = await res.json().catch(() => null)
    return { ok: res.ok, status: res.status, json }
  } finally {
    clearTimeout(id)
  }
}

async function fetchMarket() {
  const url = 'https://api.coingecko.com/api/v3/simple/price?ids=bitcoin,ethereum,solana&vs_currencies=usd&include_24hr_change=true&include_market_cap=true&include_24hr_vol=true'
  const { ok, json } = await fetchJson(url, 7000)
  if (!ok || !json) throw new Error('market_fetch_failed')

  const btc = json?.bitcoin || {}
  const eth = json?.ethereum || {}
  const sol = json?.solana || {}

  const rows = [
    {
      symbol: 'BTC',
      id: 'bitcoin',
      price: safeNum(btc.usd),
      change24h: safeNum(btc.usd_24h_change),
      vol24h: safeNum(btc.usd_24h_vol),
      mcap: safeNum(btc.usd_market_cap),
      url: 'https://www.coingecko.com/en/coins/bitcoin',
    },
    {
      symbol: 'ETH',
      id: 'ethereum',
      price: safeNum(eth.usd),
      change24h: safeNum(eth.usd_24h_change),
      vol24h: safeNum(eth.usd_24h_vol),
      mcap: safeNum(eth.usd_market_cap),
      url: 'https://www.coingecko.com/en/coins/ethereum',
    },
    {
      symbol: 'SOL',
      id: 'solana',
      price: safeNum(sol.usd),
      change24h: safeNum(sol.usd_24h_change),
      vol24h: safeNum(sol.usd_24h_vol),
      mcap: safeNum(sol.usd_market_cap),
      url: 'https://www.coingecko.com/en/coins/solana',
    },
  ]

  return rows.filter((r) => Number.isFinite(r.price) && r.price > 0)
}

function buildMarketInsights(now: Date, rows: Array<{ symbol: string; price: number; change24h: number; vol24h: number; mcap: number; url: string }>) {
  const b = bucketKey(now)
  const sorted = [...rows].sort((a, b) => b.change24h - a.change24h)
  const top = sorted[0]
  const bottom = sorted[sorted.length - 1]
  const avg = rows.reduce((s, r) => s + r.change24h, 0) / Math.max(1, rows.length)
  const breadth = clamp(avg, -100, 100)
  const vSorted = [...rows].sort((a, b) => Math.abs(b.change24h) - Math.abs(a.change24h))
  const volLeader = vSorted[0]

  const slot = Math.floor(now.getTime() / (60 * 1000)) % 3

  const items: InsightItem[] = []
  const createdAt = now.toISOString()

  if (top) {
    items.push({
      id: `m-top-${b}`,
      title: `${top.symbol} leads 24h: ${top.change24h >= 0 ? '+' : ''}${top.change24h.toFixed(2)}%`,
      summary: `${top.symbol} price $${top.price.toLocaleString(undefined, { maximumFractionDigits: 2 })}. Based on CoinGecko 24h change and spot price.`,
      sourceType: 'market',
      sourceName: 'coingecko',
      sourceUrl: top.url,
      relatedSymbols: [top.symbol],
      publishedAt: createdAt,
      createdAt,
      dedupeKey: `market:top:${b}`,
    })
  }

  if (bottom) {
    items.push({
      id: `m-bottom-${b}`,
      title: `${bottom.symbol} under pressure 24h: ${bottom.change24h >= 0 ? '+' : ''}${bottom.change24h.toFixed(2)}%`,
      summary: `${bottom.symbol} price $${bottom.price.toLocaleString(undefined, { maximumFractionDigits: 2 })}. Useful to quickly spot short-term relative weakness.`,
      sourceType: 'market',
      sourceName: 'coingecko',
      sourceUrl: bottom.url,
      relatedSymbols: [bottom.symbol],
      publishedAt: createdAt,
      createdAt,
      dedupeKey: `market:bottom:${b}`,
    })
  }

  if (volLeader) {
    items.push({
      id: `m-vol-${b}`,
      title: `Volatility focus: ${volLeader.symbol} | |Δ| 24h = ${Math.abs(volLeader.change24h).toFixed(2)}%`,
      summary: `Higher 24h absolute moves can increase slippage and drawdown risk. Metric derived from CoinGecko 24h change.`,
      sourceType: 'market',
      sourceName: 'coingecko',
      sourceUrl: volLeader.url,
      relatedSymbols: [volLeader.symbol],
      publishedAt: createdAt,
      createdAt,
      dedupeKey: `market:vol:${b}`,
    })
  }

  items.push({
    id: `m-breadth-${b}`,
    title: `Market breadth (sample avg): ${breadth >= 0 ? '+' : ''}${breadth.toFixed(2)}%`,
    summary: `Average 24h change across BTC/ETH/SOL as a simple breadth proxy to gauge short-term risk appetite.`,
    sourceType: 'market',
    sourceName: 'coingecko',
    sourceUrl: 'https://www.coingecko.com/',
    relatedSymbols: rows.map((r) => r.symbol),
    publishedAt: createdAt,
    createdAt,
    dedupeKey: `market:breadth:${b}`,
  })

  if (slot === 0) return [items[0], items[3], items[2]].filter(Boolean) as InsightItem[]
  if (slot === 1) return [items[1], items[3], items[2]].filter(Boolean) as InsightItem[]
  return [items[2], items[3], items[0]].filter(Boolean) as InsightItem[]
}

function buildNewsInsights(now: Date, news: any[]) {
  const createdAt = now.toISOString()
  const items: InsightItem[] = []
  for (const n of (news || []).slice(0, 6)) {
    const title = String(n?.title || '').trim()
    const link = String(n?.link || '').trim()
    const source = String(n?.source || 'News').trim()
    const publishedAt = String(n?.publishedAt || createdAt)
    if (!title || !link) continue
    items.push({
      id: `n-${Buffer.from(link).toString('base64').slice(0, 12)}`,
      title,
      summary: `Source: ${source}. Open to verify the original article and timestamp.`,
      sourceType: 'news',
      sourceName: source,
      sourceUrl: link,
      relatedSymbols: [],
      publishedAt,
      createdAt,
      dedupeKey: `news:${link}`,
    })
  }
  return items
}

export default async function handler(req: NextApiRequest, res: NextApiResponse) {
  if (req.method !== 'GET') return res.status(405).json({ error: 'Method not allowed' })

  const limitRaw = safeNum(req.query.limit, 20)
  const limit = clamp(Math.floor(limitRaw), 1, 50)
  const since = String(req.query.since || '').trim()

  const locale = String(req.query.locale || req.headers['accept-language'] || 'en-US').split(',')[0]
  const g: any = globalThis as any
  if (!g.__insightsCache || !(g.__insightsCache instanceof Map)) g.__insightsCache = new Map()
  const cacheKey = `insights:${locale}`

  const cached = g.__insightsCache.get(cacheKey)
  if (cached && Date.now() - cached.ts < CACHE_TTL_MS) {
    const filtered = since
      ? cached.payload.items.filter((it: InsightItem) => new Date(it.createdAt).getTime() > new Date(since).getTime())
      : cached.payload.items
    return res.status(200).json({ ...cached.payload, items: filtered.slice(0, limit), cached: true })
  }

  try {
    const now = new Date()
    const base = baseUrlFromReq(req)
    const newsUrl = base ? `${base}/api/news?category=crypto&locale=${encodeURIComponent(locale)}` : ''
    const [marketRows, newsRes] = await Promise.all([
      fetchMarket().catch(() => []),
      newsUrl ? fetchJson(newsUrl, 8000).catch(() => ({ ok: false, status: 0, json: null })) : Promise.resolve({ ok: false, status: 0, json: null }),
    ])

    const market = buildMarketInsights(now, marketRows as any)
    const newsItems = buildNewsInsights(now, Array.isArray(newsRes?.json?.items) ? newsRes.json.items : [])
    const items = [...market, ...newsItems].slice(0, 60)

    const payload: InsightsResponse = {
      items,
      serverTime: now.toISOString(),
      cached: false,
      sources: ['coingecko', 'google-news-rss', 'coindesk', 'techcrunch', 'marketwatch'],
    }

    g.__insightsCache.set(cacheKey, { ts: Date.now(), payload })

    const filtered = since
      ? payload.items.filter((it) => new Date(it.createdAt).getTime() > new Date(since).getTime())
      : payload.items
    return res.status(200).json({ ...payload, items: filtered.slice(0, limit), cached: false })
  } catch (e: any) {
    return res.status(200).json({
      items: [],
      serverTime: new Date().toISOString(),
      cached: false,
      sources: ['fallback'],
      warning: String(e?.message || 'insights_unavailable'),
    })
  }
}
