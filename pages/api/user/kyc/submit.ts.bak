import { NextApiRequest, NextApiResponse } from 'next';
import { supabaseServer } from '@/src/lib/supabaseServer';

export default async function handler(req: NextApiRequest, res: NextApiResponse) {
  if (req.method !== 'POST') {
    return res.status(405).json({ error: 'Method not allowed' });
  }

  const authHeader = req.headers.authorization || '';
  const token = authHeader.startsWith('Bearer ') ? authHeader.slice(7).trim() : '';

  if (!token) return res.status(401).json({ error: 'Missing authorization token' });
  if (!supabaseServer) return res.status(500).json({ error: 'Supabase not configured' });

  const { data: { user }, error: userErr } = await supabaseServer.auth.getUser(token);
  if (userErr || !user) return res.status(401).json({ error: 'Invalid or expired token' });

  const { applicationId, files, details } = req.body;

  if (!applicationId) return res.status(400).json({ error: 'applicationId is required' });
  if (!files?.idPath) return res.status(400).json({ error: 'files.idPath is required' });
  if (!details) return res.status(400).json({ error: 'details payload is required' });

  try {
    const now = new Date().toISOString();
    const level = Number(details?.level || 1);

    // 1) Write the full KYC application (single source of truth for admin review)
    const { error: kycErr } = await supabaseServer
      .from('kyc_applications')
      .upsert(
        {
          id: applicationId,
          user_id: user.id,
          status: 'pending',
          level,
          details,
          files,
          submitted_at: now,
        },
        { onConflict: 'id' }
      );

    if (kycErr) throw kycErr;

    // 2) Keep lightweight status fields in profiles for quick UI reads
    await supabaseServer
      .from('profiles')
      .upsert(
        {
          user_id: user.id,
          email: user.email,
          kyc_status: 'pending',
          kyc_level: level,
          kyc_submitted_at: now,
        },
        { onConflict: 'user_id' }
      );

    // 3) Keep auth-facing status in User table (used by dashboard badge)
    await supabaseServer
      .from('User')
      .upsert(
        {
          id: user.id,
          email: user.email,
          kycStatus: 'PENDING',
          kycDocument: files?.idUrl || null,
          updatedAt: now,
        },
        { onConflict: 'id' }
      );

    return res.status(200).json({ message: 'KYC submitted successfully', applicationId });
  } catch (err: any) {
    console.error('KYC Submit Error:', err);
    return res.status(500).json({ error: err.message || 'Failed to submit KYC' });
  }
}
