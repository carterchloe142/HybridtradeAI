import { NextApiRequest, NextApiResponse } from 'next';
import { supabaseServer } from '@/src/lib/supabaseServer';

export default async function handler(req: NextApiRequest, res: NextApiResponse) {
  if (req.method !== 'GET') {
    return res.status(405).json({ error: 'Method not allowed' });
  }

  const authHeader = req.headers.authorization || '';
  const token = authHeader.startsWith('Bearer ') ? authHeader.slice(7).trim() : '';

  if (!token) return res.status(401).json({ error: 'Missing authorization token' });
  if (!supabaseServer) return res.status(500).json({ error: 'Supabase not configured' });

  const { data: { user }, error: userErr } = await supabaseServer.auth.getUser(token);
  if (userErr || !user) return res.status(401).json({ error: 'Invalid or expired token' });

  try {
    // 1) Primary source: latest KYC application
    const { data: app } = await supabaseServer
      .from('kyc_applications')
      .select('id, status, level, submitted_at, decided_at, reject_reason, files')
      .eq('user_id', user.id)
      .order('created_at', { ascending: false })
      .limit(1)
      .maybeSingle();

    if (app) {
      const s = String(app.status || 'pending').toLowerCase();
      const userFacingStatus = s === 'approved' ? 'verified' : s;
      return res.status(200).json({
        status: userFacingStatus,
        level: app.level || 1,
        rejectReason: app.reject_reason || null,
        submittedAt: app.submitted_at || null,
        decidedAt: app.decided_at || null,
        applicationId: app.id,
      });
    }

    // 2) Fallback: profiles legacy flags
    const { data: profile } = await supabaseServer
      .from('profiles')
      .select('kyc_status, kyc_level, kyc_submitted_at')
      .eq('user_id', user.id)
      .maybeSingle();

    if (profile?.kyc_status) {
      const s = String(profile.kyc_status).toLowerCase();
      const userFacingStatus = s === 'approved' ? 'verified' : s;
      return res.status(200).json({
        status: userFacingStatus,
        level: profile.kyc_level || 1,
        rejectReason: null,
        submittedAt: profile.kyc_submitted_at || null,
        decidedAt: null,
        applicationId: null,
      });
    }

    return res.status(200).json({
      status: 'not_submitted',
      level: 1,
      rejectReason: null,
      submittedAt: null,
      decidedAt: null,
      applicationId: null,
    });
  } catch (err: any) {
    console.error('KYC Status Error:', err);
    return res.status(500).json({ error: err.message || 'Failed to fetch KYC status' });
  }
}
